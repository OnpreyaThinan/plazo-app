# คัดลอกไฟล์นี้ไปเป็น android/key.properties แล้วแก้ค่าด้านล่างให้เป็นของจริง
#
# วิธีใช้งาน:
# 1) สร้างไฟล์ keystore (.jks) ก่อน
# 2) วางไฟล์ .jks ไว้ที่โฟลเดอร์ android/
# 3) เปลี่ยนชื่อไฟล์นี้เป็น key.properties
#    ตัวอย่างคำสั่ง PowerShell:
#    Rename-Item android\key.properties.example android\key.properties
#
# คำอธิบายแต่ละ field:
# storePassword = รหัสผ่านของไฟล์ keystore (.jks)
# keyPassword   = รหัสผ่านของ key ภายใน keystore
# keyAlias      = ชื่อ alias ที่สร้างไว้ตอน generate keystore
# storeFile     = พาธไปยังไฟล์ .jks เมื่อเทียบกับโฟลเดอร์ android/

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=YOUR_KEY_ALIAS
storeFile=../upload-keystore.jks
